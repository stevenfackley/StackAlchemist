# ─── Version control ──────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ─── CI / GitHub ──────────────────────────────────────────────────────────────
.github/

# ─── Environment files (never bake secrets into images) ───────────────────────
.env
.env.*
*.env

# ─── .NET build artefacts ─────────────────────────────────────────────────────
**/bin/
**/obj/

# ─── Node / Next.js build artefacts ──────────────────────────────────────────
**/node_modules/
**/.next/
**/dist/
**/build/
**/.pnpm-store/
**/test-results/
**/coverage/
**/playwright-report/
**/e2e-results/
**/*.tsbuildinfo

# ─── IDE & OS noise ───────────────────────────────────────────────────────────
.vs/
.vscode/
.idea/
.DS_Store
Thumbs.db

# ─── Docs / scripts / docker config (not needed inside images) ───────────────
# NOTE: docs/ is intentionally NOT ignored — web-builder COPY docs/ /docs/ uses
# it for /docs/[...slug] prerendering. content/ is also required for blog,
# compare, and solutions prerendering.
scripts/
docker/

# ─── Misc project files ───────────────────────────────────────────────────────
# Scoped to repo root so content/**/*.md and docs/**/*.md reach the build context.
/*.md
LICENSE
cliff.toml
products.csv
temp/
logs/
generated_repos/
reconstruction/
*.zip
