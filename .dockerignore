# ─── Version control ──────────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ─── CI / GitHub ──────────────────────────────────────────────────────────────
.github/

# ─── Environment files (never bake secrets into images) ───────────────────────
.env
.env.*
*.env

# ─── .NET build artefacts ─────────────────────────────────────────────────────
**/bin/
**/obj/

# ─── Node / Next.js build artefacts ──────────────────────────────────────────
**/node_modules/
**/.next/
**/dist/
**/build/
**/.pnpm-store/
**/test-results/
**/coverage/
**/playwright-report/
**/e2e-results/
**/*.tsbuildinfo

# ─── IDE & OS noise ───────────────────────────────────────────────────────────
.vs/
.vscode/
.idea/
.DS_Store
Thumbs.db

# ─── Docs / docker config (not needed inside images) ─────────────────────────
docs/
docker/

# ─── Misc project files ───────────────────────────────────────────────────────
*.md
LICENSE
cliff.toml
products.csv
temp/
logs/
generated_repos/
reconstruction/
*.zip
