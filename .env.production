# StackAlchemist Environment Variables (Production)
# Target: GitHub Actions Environment: Prod

# Frontend (Next.js)
NEXT_PUBLIC_APP_URL="https://stackalchemist.app"

# Backend (.NET 10 API)
ASPNETCORE_ENVIRONMENT="Production"
API_PORT="80"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="${SUPABASE_URL}"
NEXT_PUBLIC_SUPABASE_ANON_KEY="${SUPABASE_ANON_KEY}"
SUPABASE_SERVICE_ROLE_KEY="${SUPABASE_SERVICE_ROLE_KEY}"

# Cloudflare R2
R2_ACCOUNT_ID="${CF_ACCOUNT_ID}"
R2_ACCESS_KEY_ID="${R2_ACCESS_KEY_ID}"
R2_SECRET_ACCESS_KEY="${R2_SECRET_ACCESS_KEY}"
R2_BUCKET_NAME="stackalchemist-generations-prod"
R2_PUBLIC_URL="https://downloads.stackalchemist.app"
R2_S3_URL="https://${CF_ACCOUNT_ID}.r2.cloudflarestorage.com"

# Stripe (Live Mode)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="${STRIPE_PUBLISHABLE_KEY}"
STRIPE_SECRET_KEY="${STRIPE_SECRET_KEY}"
STRIPE_WEBHOOK_SECRET="${STRIPE_WEBHOOK_SECRET}"

# LLM APIs
ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY}"
