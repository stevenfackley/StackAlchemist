# StackAlchemist Environment Variables (Production)
# Populated by GitHub Actions Secrets at build time
# Target: AWS Production Environment

# Frontend (Next.js)
NEXT_PUBLIC_APP_URL="https://stackalchemist.app"

# Backend (.NET 10 API)
ASPNETCORE_ENVIRONMENT="Production"
API_PORT="80"

# Supabase (Production Project)
NEXT_PUBLIC_SUPABASE_URL="https://prod-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="${PROD_SUPABASE_ANON_KEY}"
SUPABASE_SERVICE_ROLE_KEY="${PROD_SUPABASE_SERVICE_ROLE_KEY}"

# Cloudflare R2 (Production Bucket)
R2_ACCOUNT_ID="${CF_ACCOUNT_ID}"
R2_ACCESS_KEY_ID="${PROD_R2_ACCESS_KEY}"
R2_SECRET_ACCESS_KEY="${PROD_R2_SECRET_KEY}"
R2_BUCKET_NAME="stackalchemist-generations-prod"
R2_PUBLIC_URL="https://downloads.stackalchemist.app"

# Stripe (Live Mode)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="${PROD_STRIPE_PUB_KEY}"
STRIPE_SECRET_KEY="${PROD_STRIPE_SECRET_KEY}"
STRIPE_WEBHOOK_SECRET="${PROD_STRIPE_WEBHOOK_SECRET}"

# LLM APIs
ANTHROPIC_API_KEY="${PROD_ANTHROPIC_API_KEY}"
