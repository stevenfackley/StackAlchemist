    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-config-next": "^16.2.4",
    "jsdom": "^29.1.1",
    "msw": "^2.14.3",
