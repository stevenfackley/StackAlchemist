{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Anthropic": {
    "Model": "claude-sonnet-4-6",
    "MaxTokens": "8192"
  },
  "CloudflareR2": {
    "BucketName": "stackalchemist-builds",
    "PresignedUrlExpiryHours": "168"
  },
  "Stripe": {
    "PublishableKey": ""
  },
  "Engine": {
    "AllowedOrigins": "http://localhost:3000"
  }
}
