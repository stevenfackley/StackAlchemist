# StackAlchemist Environment Variables — Example / Template
# Copy this file to .env and fill in real values for local development.
# In CI/CD, .env files are generated automatically by GitHub Actions from repository secrets.
# See .github/actions/setup-env/action.yml for the mapping.
#
# DO NOT commit .env, .env.development, .env.test, or .env.production files.

# ─── Frontend (Next.js) ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Backend (.NET API) ──────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT="Development"
API_PORT="5000"

# ─── Supabase ────────────────────────────────────────────────────────────────
# GitHub Actions secret: SUPABASE_URL
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
# GitHub Actions secret: SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-local-anon-key"
# GitHub Actions secret: SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SERVICE_ROLE_KEY="your-local-service-role-key"

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
# GitHub Actions secret: CF_ACCOUNT_ID
R2_ACCOUNT_ID="your-cloudflare-account-id"
# GitHub Actions secret: R2_ACCESS_KEY_ID
R2_ACCESS_KEY_ID="your-r2-access-key-id"
# GitHub Actions secret: R2_SECRET_ACCESS_KEY
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="stackalchemist-generations-dev"
R2_PUBLIC_URL="https://pub-dev.yourdomain.r2.dev"
R2_S3_URL="https://your-cloudflare-account-id.r2.cloudflarestorage.com"
R2_ENDPOINT="https://your-cloudflare-account-id.r2.cloudflarestorage.com"

# ─── Cloudflare Tunnel (Test/Staging only) ───────────────────────────────────
# GitHub Actions secret: CLOUDFLARE_TUNNEL_TOKEN
CLOUDFLARE_TUNNEL_TOKEN="your-cloudflare-tunnel-token"

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Use test-mode keys for development; live keys are stored as GitHub Actions secrets.
# GitHub Actions secret: STRIPE_PUBLISHABLE_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# GitHub Actions secret: STRIPE_SECRET_KEY
STRIPE_SECRET_KEY="sk_test_..."
# GitHub Actions secret: STRIPE_WEBHOOK_SECRET
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── LLM APIs ────────────────────────────────────────────────────────────────
# GitHub Actions secret: ANTHROPIC_API_KEY
ANTHROPIC_API_KEY="sk-ant-..."
