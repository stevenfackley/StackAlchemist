# StackAlchemist — Environment Variables Template
# ──────────────────────────────────────────────────────────────────────────────
#
# HOW TO USE THIS FILE
# ────────────────────
# 1. Run `node scripts/setup-env.mjs` from the solution root (or just run
#    `pnpm install` inside src/StackAlchemist.Web — it runs automatically).
#    That will copy this file to `.env` in the solution root.
#
# 2. Open the newly created `.env` and fill in your real values for any key
#    that still contains a placeholder (e.g. "sk-ant-...", "your-account-id").
#
# 3. Leave this file (.env.example) alone — it is committed to git and contains
#    only dummy/placeholder values. NEVER put real secrets in this file.
#
# WHY ONLY ONE .env FILE?
# ────────────────────────
# StackAlchemist uses a single `.env` for all environments because three
# separate processes need the same secrets:
#
#   • Next.js frontend    (reads NEXT_PUBLIC_* vars automatically)
#   • .NET Engine API     (reads via DotNetEnv at startup)
#   • Docker Compose      (loads .env from the project root automatically)
#
# Per-environment differences (dev vs staging vs prod) are handled by the
# deployment pipeline (GitHub Actions secrets), not by multiple .env files.
#
# DO NOT COMMIT:  .env  or any file matching  .env.*  (all gitignored)
# DO COMMIT:      .env.example  (this file — safe because it has no real secrets)

# ─── Frontend (Next.js) ──────────────────────────────────────────────────────
# The URL the browser uses to reach the app (used for redirects, og:url, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Backend (.NET Engine API) ───────────────────────────────────────────────
# Controls which appsettings file the Engine loads (Development | Production)
ASPNETCORE_ENVIRONMENT="Development"
# Port the Engine listens on (must match docker-compose.yml and frontend proxy)
API_PORT="5000"

# ─── Supabase ────────────────────────────────────────────────────────────────
# Local Supabase instance (started with `supabase start`).
# For production, replace with your project's URL from supabase.com → Settings → API.
# GitHub Actions secret: SUPABASE_URL
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
# Anon key — safe to expose in the browser; Row Level Security controls access.
# GitHub Actions secret: SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-local-anon-key"
# Service-role key — NEVER expose in the browser; used only by the .NET Engine.
# GitHub Actions secret: SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SERVICE_ROLE_KEY="your-local-service-role-key"

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
# R2 stores the generated project zip files and serves presigned download URLs.
# Get these from Cloudflare Dashboard → R2 → Manage R2 API tokens.
# GitHub Actions secret: CF_ACCOUNT_ID
R2_ACCOUNT_ID="your-cloudflare-account-id"
# GitHub Actions secret: R2_ACCESS_KEY_ID
R2_ACCESS_KEY_ID="your-r2-access-key-id"
# GitHub Actions secret: R2_SECRET_ACCESS_KEY
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
# Bucket name — use a dev bucket locally to avoid polluting production data.
R2_BUCKET_NAME="stackalchemist-generations-dev"
# Public URL for the bucket (only needed if the bucket has public access enabled).
R2_PUBLIC_URL="https://pub-dev.yourdomain.r2.dev"
# S3-compatible endpoint for the AWS SDK (DotNetEnv maps R2_ACCOUNT_ID → this).
R2_S3_URL="https://your-cloudflare-account-id.r2.cloudflarestorage.com"
R2_ENDPOINT="https://your-cloudflare-account-id.r2.cloudflarestorage.com"

# ─── Cloudflare Tunnel (staging/CI only) ─────────────────────────────────────
# Used in the Proxmox LXC staging environment to expose the app via a secure
# Cloudflare Tunnel without opening inbound firewall rules.
# GitHub Actions secret: CLOUDFLARE_TUNNEL_TOKEN
CLOUDFLARE_TUNNEL_TOKEN="your-cloudflare-tunnel-token"

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Use test-mode keys locally (they start with pk_test_ / sk_test_).
# Live keys are injected by GitHub Actions and NEVER go in .env files.
# Get test keys from: dashboard.stripe.com → Developers → API keys
# GitHub Actions secret: STRIPE_PUBLISHABLE_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# GitHub Actions secret: STRIPE_SECRET_KEY
STRIPE_SECRET_KEY="sk_test_..."
# Get the webhook secret from: dashboard.stripe.com → Developers → Webhooks
# GitHub Actions secret: STRIPE_WEBHOOK_SECRET
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── LLM API ─────────────────────────────────────────────────────────────────
# Anthropic Claude API key — used for code generation in production.
# If this is left empty the Engine falls back to MockLlmClient (safe for local
# development without spending API credits).
# Get a key from: console.anthropic.com → API Keys
# GitHub Actions secret: ANTHROPIC_API_KEY
ANTHROPIC_API_KEY="sk-ant-..."
