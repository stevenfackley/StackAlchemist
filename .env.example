# StackAlchemist Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your real secrets.
# See docs/architecture/Dev Environment Setup.md for more details.

# ── Frontend (Next.js) ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_IS_TEST_SITE=false
ENGINE_API_URL=http://localhost:5000

# ── Backend (.NET API) ──────────────────────────────────────────────────────
# Set to 'Production' to enable production-specific validation (secrets required).
ASPNETCORE_ENVIRONMENT=Development
API_PORT=5000

# ── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Cloudflare R2 (Storage) ─────────────────────────────────────────────────
# Buckets: stackalchemist-generations-dev | *-test | *-prod
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=stackalchemist-generations-dev
R2_PUBLIC_URL=https://pub-dev.stackalchemist.app

# ── Cloudflare Tunnel (Networking) ─────────────────────────────────────────
# Required only for production or staging deployments via Docker Compose.
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token

# ── Stripe (Payments) ──────────────────────────────────────────────────────
# Get these from your Stripe Dashboard > Developers > API keys / Webhooks.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── LLM APIs ───────────────────────────────────────────────────────────────
# Get this from your Anthropic Console (https://console.anthropic.com/).
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Engine Security ─────────────────────────────────────────────────────────
# Shared secret for Next.js -> Engine API authentication (X-Engine-Key header).
# Required when ASPNETCORE_ENVIRONMENT=Production.
ENGINE_SERVICE_KEY=your-long-random-service-key
