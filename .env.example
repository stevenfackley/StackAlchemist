# StackAlchemist Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in your real secrets.
# See docs/architecture/Dev Environment Setup.md for more details.

# ── Frontend (Next.js) ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_IS_TEST_SITE=false
ENGINE_API_URL=http://localhost:5000

# ── Test Site Protection (test mirror only) ─────────────────────────────────
# HTTP Basic Auth credentials enforced by src/middleware.ts when
# NEXT_PUBLIC_IS_TEST_SITE=true. Leave blank for prod and local dev.
# /api/healthz is exempt so Docker/tunnel probes keep working.
TEST_SITE_BASIC_AUTH_USER=
TEST_SITE_BASIC_AUTH_PASS=

# ── SEO / Analytics (optional, prod only) ───────────────────────────────────
# Plausible analytics domain (e.g. "stackalchemist.app"). When set, a Plausible
# <script> is injected in the root layout. Left empty → no tracking loaded.
# Never set this for the test site — only prod should report to Plausible.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Google Search Console verification token (from the GSC HTML tag method,
# value only — not the full meta tag). Renders as <meta name="google-site-verification" ...>.
GOOGLE_SITE_VERIFICATION=

# ── Backend (.NET API) ──────────────────────────────────────────────────────
# Set to 'Production' to enable production-specific validation (secrets required).
ASPNETCORE_ENVIRONMENT=Development
API_PORT=5000

# ── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Cloudflare R2 (Storage) ─────────────────────────────────────────────────
# Buckets: stackalchemist-generations-dev | *-test | *-prod
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=stackalchemist-generations-dev
R2_PUBLIC_URL=https://pub-dev.stackalchemist.app

# ── Cloudflare Tunnel (Networking) ─────────────────────────────────────────
# Required only for production or staging deployments via Docker Compose.
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token

# ── Stripe (Payments) ──────────────────────────────────────────────────────
# Get these from your Stripe Dashboard > Developers > API keys / Webhooks.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── LLM APIs ───────────────────────────────────────────────────────────────
# Get this from your Anthropic Console (https://console.anthropic.com/).
ANTHROPIC_API_KEY=sk-ant-api03-...
# Used by the Next.js dashboard to encrypt user BYOK values before storing them.
# Use a high-entropy value with at least 32 characters.
BYOK_ENCRYPTION_KEY=your-long-random-byok-encryption-key

# ── Engine Security ─────────────────────────────────────────────────────────
# Shared secret for Next.js -> Engine API authentication (X-Engine-Key header).
# Required when ASPNETCORE_ENVIRONMENT=Production.
ENGINE_SERVICE_KEY=your-long-random-service-key
