.env
.env.*
!.env.example
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pnpm-lock.yaml

# OS and IDE Specific
.DS_Store
Thumbs.db
.vscode/
.idea/

# StackAlchemist Generation Engine (Temporary)
temp/
reconstruction/
*.zip
logs/
generated_repos/

# Supabase Local Development
supabase/.temp/
supabase/functions/.env

# AI Agent Specific
AGENTS.md
claude.md
docs/DEV_PROMPT.md
.claude/

# Design reference extracts
style-extracted/
.pnpm-store/

# Squirrelscan audit output (snapshots, not source)
squirrel-audit-*.txt
squirrel-audit-*.json
squirrel-audit-*.html
*.lscache
