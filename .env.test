# StackAlchemist Environment Variables (Test/Staging)
# Target: GitHub Actions Environment: Test

# Frontend (Next.js)
NEXT_PUBLIC_APP_URL="https://test.stackalchemist.app"

# Backend (.NET 10 API)
ASPNETCORE_ENVIRONMENT="Staging"
API_PORT="5000"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="${SUPABASE_URL}"
NEXT_PUBLIC_SUPABASE_ANON_KEY="${SUPABASE_ANON_KEY}"
SUPABASE_SERVICE_ROLE_KEY="${SUPABASE_SERVICE_ROLE_KEY}"

# Cloudflare R2
R2_ACCOUNT_ID="${CF_ACCOUNT_ID}"
R2_ACCESS_KEY_ID="${R2_ACCESS_KEY_ID}"
R2_SECRET_ACCESS_KEY="${R2_SECRET_ACCESS_KEY}"
R2_BUCKET_NAME="stackalchemist-generations-test"
R2_PUBLIC_URL="https://pub-test.stackalchemist.app"
R2_S3_URL="https://${CF_ACCOUNT_ID}.r2.cloudflarestorage.com"

# Stripe (Test Mode)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="${STRIPE_PUBLISHABLE_KEY}"
STRIPE_SECRET_KEY="${STRIPE_SECRET_KEY}"
STRIPE_WEBHOOK_SECRET="${STRIPE_WEBHOOK_SECRET}"

# LLM APIs
ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY}"
