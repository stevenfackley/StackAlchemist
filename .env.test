# StackAlchemist Environment Variables (Test/Staging)
# Loaded dynamically via GitHub Actions / Docker Compose
# Target: Local Proxmox LXC Container routed via Cloudflare Tunnels

# Frontend (Next.js)
NEXT_PUBLIC_APP_URL="https://test.stackalchemist.app"

# Backend (.NET 10 API)
ASPNETCORE_ENVIRONMENT="Staging"
API_PORT="5000"

# Supabase (Staging Project)
NEXT_PUBLIC_SUPABASE_URL="https://staging-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="${TEST_SUPABASE_ANON_KEY}"
SUPABASE_SERVICE_ROLE_KEY="${TEST_SUPABASE_SERVICE_ROLE_KEY}"

# Cloudflare R2 (Staging Bucket)
R2_ACCOUNT_ID="${CF_ACCOUNT_ID}"
R2_ACCESS_KEY_ID="${TEST_R2_ACCESS_KEY}"
R2_SECRET_ACCESS_KEY="${TEST_R2_SECRET_KEY}"
R2_BUCKET_NAME="stackalchemist-generations-test"
R2_PUBLIC_URL="https://pub-test.stackalchemist.app"

# Stripe (Test Mode)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="${TEST_STRIPE_PUB_KEY}"
STRIPE_SECRET_KEY="${TEST_STRIPE_SECRET_KEY}"
STRIPE_WEBHOOK_SECRET="${TEST_STRIPE_WEBHOOK_SECRET}"

# LLM APIs
ANTHROPIC_API_KEY="${TEST_ANTHROPIC_API_KEY}"
